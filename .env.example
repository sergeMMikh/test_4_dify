# Dify app settings
DIFY_API_KEY=app-your-dify-api-key
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_RESPONSE_MODE=blocking
DIFY_TIMEOUT_SECONDS=30
DIFY_USER_ID=interactive-console

# Langfuse SDK settings used by this app
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PORT=3001
LANGFUSE_BASE_URL=http://localhost:3001

# Langfuse self-hosting settings for docker-compose
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-with-a-long-random-secret
SALT=replace-with-a-stable-random-salt
ENCRYPTION_KEY=replace-with-a-64-byte-hex-key
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-postgres-password
POSTGRES_DB=langfuse
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=replace-with-a-clickhouse-password
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=replace-with-a-minio-password
REDIS_AUTH=replace-with-a-redis-password

# Optional Langfuse bootstrap data
# Keep these project keys in sync with LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY.
LANGFUSE_INIT_ORG_NAME=example-org
LANGFUSE_INIT_PROJECT_NAME=test-4-dify
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_INIT_USER_EMAIL=admin@example.local
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=replace-with-an-admin-password
